name = "xmcl-web-api-mot-preview"
main = "worker.ts"
compatibility_date = "2024-09-23"
compatibility_flags = ["nodejs_compat"]

# This config is intentionally separate from wrangler.toml. Replace values with
# preview-only resources and keep secrets in `wrangler secret put`.
[vars]
MONGODB_NAME = "xmcl-api-preview-mot"
TURNS = ""

[[durable_objects.bindings]]
name = "GROUP_ROOM"
class_name = "GroupRoom"

[[migrations]]
tag = "mot-v1"
new_sqlite_classes = ["GroupRoom"]

[triggers]
crons = ["0 0 * * *"]
