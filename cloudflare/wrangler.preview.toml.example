name = "xmcl-web-api-mot-preview"
main = "worker.ts"
compatibility_date = "2024-09-23"
compatibility_flags = ["nodejs_compat"]

# This config is intentionally separate from wrangler.toml. Replace values with
# preview-only resources and keep secrets in `wrangler secret put`.
[vars]
MONGODB_NAME = "xmcl-api-preview-mot"
TURNS = ""
XMCL_COMMERCIAL_ENABLED = "false"

[[durable_objects.bindings]]
name = "GROUP_ROOM"
class_name = "GroupRoom"

[[migrations]]
tag = "mot-v1"
new_sqlite_classes = ["GroupRoom"]

[[kv_namespaces]]
binding = "TRANSLATION_KV"
id = "REPLACE_WITH_PREVIEW_KV_NAMESPACE_ID"

[[queues.producers]]
binding = "TRANSLATION_QUEUE"
queue = "xmcl-translation-mot"

[[queues.consumers]]
queue = "xmcl-translation-mot"
max_batch_size = 1
max_retries = 3

[triggers]
crons = ["0 0 * * *"]
