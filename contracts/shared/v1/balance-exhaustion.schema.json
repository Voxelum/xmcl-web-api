{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xmcl.app/contracts/shared/v1/balance-exhaustion.schema.json",
  "title": "Server balance-exhaustion stop v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventType",
    "eventId",
    "schemaVersion",
    "serverId",
    "leaseId",
    "settlementId",
    "reason",
    "occurredAt"
  ],
  "properties": {
    "eventType": { "const": "runtime.stopped.v1" },
    "eventId": { "type": "string", "minLength": 1 },
    "schemaVersion": { "const": 1 },
    "serverId": { "type": "string", "minLength": 1 },
    "leaseId": { "type": "string", "minLength": 1 },
    "settlementId": { "type": "string", "minLength": 1 },
    "reason": { "const": "balance_exhausted" },
    "occurredAt": { "type": "string", "format": "date-time" }
  }
}
