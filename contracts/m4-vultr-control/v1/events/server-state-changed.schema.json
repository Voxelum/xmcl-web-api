{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xmcl.app/contracts/m4-vultr-control/v1/events/server-state-changed.schema.json",
  "title": "M4 server state changed v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventType", "eventId", "schemaVersion", "accountId", "serverId", "status", "desiredStatus", "statusVersion", "occurredAt"],
  "properties": {
    "eventType": { "const": "server.state.changed.v1" },
    "eventId": { "type": "string", "minLength": 1 },
    "schemaVersion": { "const": 1 },
    "accountId": { "type": "string", "minLength": 1 },
    "serverId": { "type": "string", "minLength": 1 },
    "status": { "enum": ["creating", "stopped", "starting", "running", "stopping", "suspended", "billing_blocked", "failed", "deleting", "deleted"] },
    "desiredStatus": { "enum": ["running", "stopped", "deleted"] },
    "statusVersion": { "type": "integer", "minimum": 1 },
    "reason": { "type": "string" },
    "taskId": { "type": "string", "minLength": 1 },
    "occurredAt": { "type": "string", "format": "date-time" }
  }
}
