{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xmcl.app/contracts/m1-account-and-identity/v1/events/account-merge.schema.json",
  "title": "XMCL Account Merge Event v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventType",
    "eventId",
    "schemaVersion",
    "idempotencyKey",
    "mergeId",
    "sourceAccountId",
    "targetAccountId",
    "status",
    "occurredAt"
  ],
  "properties": {
    "eventType": { "const": "account.merge.v1" },
    "eventId": { "type": "string", "minLength": 1 },
    "schemaVersion": { "const": 1 },
    "idempotencyKey": { "type": "string", "minLength": 1, "maxLength": 255 },
    "mergeId": { "type": "string", "minLength": 1 },
    "sourceAccountId": { "type": "string", "minLength": 1 },
    "targetAccountId": { "type": "string", "minLength": 1 },
    "identityProvider": {
      "enum": ["microsoft", "modrinth", "google", "discord"]
    },
    "status": { "enum": ["prepared", "completed"] },
    "taskId": { "type": "string", "minLength": 1 },
    "occurredAt": { "type": "string", "format": "date-time" }
  }
}
