{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xmcl.app/contracts/m1-account-and-identity/v1/events/session-lifecycle.schema.json",
  "title": "XMCL Session Lifecycle Event v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventType",
    "eventId",
    "schemaVersion",
    "idempotencyKey",
    "action",
    "accountId",
    "sessionId",
    "familyId",
    "occurredAt"
  ],
  "properties": {
    "eventType": { "const": "account.session.lifecycle.v1" },
    "eventId": { "type": "string", "minLength": 1 },
    "schemaVersion": { "const": 1 },
    "idempotencyKey": { "type": "string", "minLength": 1, "maxLength": 255 },
    "action": {
      "enum": ["issued", "refreshed", "revoked", "refresh_replayed"]
    },
    "accountId": { "type": "string", "minLength": 1 },
    "sessionId": { "type": "string", "minLength": 1 },
    "familyId": { "type": "string", "minLength": 1 },
    "occurredAt": { "type": "string", "format": "date-time" }
  }
}
