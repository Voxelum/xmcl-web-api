{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xmcl.app/contracts/m1-account-and-identity/v1/identity.schema.json",
  "title": "Public XMCL Account Identity v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["provider", "linkedBy", "linkedAt"],
  "properties": {
    "provider": { "enum": ["microsoft", "modrinth", "google", "discord"] },
    "displayName": { "type": "string", "minLength": 1, "maxLength": 256 },
    "linkedBy": {
      "enum": ["launcher_bootstrap", "launcher_link", "web_link"]
    },
    "linkedAt": { "type": "string", "format": "date-time" }
  }
}
